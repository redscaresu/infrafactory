[0.012, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "# InfraFactory: scenario-driven IaC with LLM agents + mock-backed validation\r\n\r\n"]
[2.008, "o", "$ infrafactory --help\r\n"]
[1.078, "o", "Scenario-driven infrastructure generation and validation for Scaleway\r\n\r\nUsage:\r\n  infrafactory [command]\r\n\r\nAvailable Commands:\r\n  completion  Generate the autocompletion script for the specified shell\r\n  generate    Generate OpenTofu files from a scenario\r\n  help        Help about any command\r\n  init        Initialize an infrafactory scenario scaffold\r\n  mock        Manage mock service dependencies\r\n  run         Run generation and validation loop\r\n  test        Run harness checks for a scenario\r\n  ui          Serve the InfraFactory web UI\r\n  validate    Validate generated infrastructure definitions\r\n\r\n"]
[5.009, "o", "\r\n$ infrafactory mock status\r\n"]
[1.045, "o", "Command: mock status\r\nScenario: n/a\r\nStatus: success\r\n\r\nStages:\r\n- mock/preflight: pass\r\n- mock/status: pass (stopped)\r\n{\"level\":\"info\",\"command\":\"mock status\",\"event\":\"command_end\",\"status\":\"success\"}\r\n"]
[3.008, "o", "\r\n"]
[0.001, "o", "# Step 1 — Declare intent (scenarios/training/registry-paris.yaml):\r\n"]
[1.012, "o", "scenario: registry-paris\r\nversion: \"1.0\"\r\ncloud: scaleway\r\ndescription: >\r\n  A private container registry namespace in Paris for storing\r\n  application Docker images.\r\n\r\nresources:\r\n  registry:\r\n    purpose: app-images\r\n    is_public: false\r\n\r\nacceptance_criteria:\r\n  - type: policy\r\n    check: region_restriction\r\n    params:\r\n      region: fr-par\r\n    expect: pass\r\n  - type: destruction\r\n    expect: no_orphans\r\n"]
[5.008, "o", "\r\n# Step 2 — Run the pipeline (Claude generates → mockway validates → retries on failure):\r\n"]
[2.057, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"command_start\",\"status\":\"start\"}\r\n"]
[0.011, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"run_start\",\"status\":\"start\",\"run_id\":\"20260524T224738Z\",\"detail\":\"repair_iterations_max=5 run_mode=clean no_destroy=false previous_run_id=\"}\r\n"]
[0.001, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"iteration_start\",\"status\":\"start\",\"run_id\":\"20260524T224738Z\",\"iteration\":1}\r\n"]
[0.000, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_start\",\"status\":\"start\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_generate\"}\r\n"]
[2.911, "o", "generator/claude: phase \"plan_architecture\" start\r\n"]
[5.357, "o", "generator/claude: phase \"plan_architecture\" complete\r\n"]
[0.007, "o", "generator/claude: phase \"generate_hcl\" start\r\n"]
[6.502, "o", "generator/claude: phase \"generate_hcl\" complete\r\n"]
[0.000, "o", "generator/claude: phase \"self_review\" start\r\n"]
[2.345, "o", "generator/claude: phase \"self_review\" complete\r\ngenerator/claude: phase \"self_review\": no changes indicated\r\n"]
[0.020, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_end\",\"status\":\"success\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_generate\"}\r\n"]
[0.000, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_start\",\"status\":\"start\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_validate\"}\r\n"]
[2.340, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_end\",\"status\":\"success\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_validate\"}\r\n{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_start\",\"status\":\"start\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_test\"}\r\n"]
[0.558, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"stage_end\",\"status\":\"success\",\"run_id\":\"20260524T224738Z\",\"iteration\":1,\"stage\":\"iteration_1_test\"}\r\n"]
[0.000, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"iteration_end\",\"status\":\"success\",\"run_id\":\"20260524T224738Z\",\"iteration\":1}\r\n"]
[0.000, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"terminal_reason\",\"status\":\"target_reached\",\"run_id\":\"20260524T224738Z\",\"detail\":\"completed_iterations=1\"}\r\n"]
[0.000, "o", "Command: run\r\nScenario: registry-paris\r\nStatus: success\r\n\r\nStages:\r\n- holdout/discovery: pass (0 holdouts)\r\n- run/iteration_1_generate: pass\r\n- run/iteration_1_test: pass\r\n- run/iteration_1_validate: pass\r\n- run/metadata: pass (run_id=20260524T224738Z)\r\n- run/mode: pass (clean (missing mockway state))\r\n- run/terminal_reason: pass (target_reached)\r\n"]
[0.000, "o", "{\"level\":\"info\",\"command\":\"run\",\"event\":\"command_end\",\"status\":\"success\"}\r\n"]
[2.008, "o", "\r\n"]
[0.000, "o", "# Step 3 — The generated OpenTofu the model converged on:\r\n"]
[1.010, "o", "\r\n$ ls output/registry-paris/\r\n"]
[0.007, "o", "main.tf\r\noutputs.tf\r\nproviders.tf\r\nterraform.tfstate\r\nvariables.tf\r\n"]
[3.008, "o", "\r\n$ cat output/registry-paris/main.tf\r\n"]
[1.016, "o", "resource \"scaleway_registry_namespace\" \"app_images\" {\r\n  name      = var.registry_name\r\n  region    = var.region\r\n  is_public = var.is_public\r\n}"]
[4.009, "o", "\r\n$ cat output/registry-paris/providers.tf\r\n"]
[1.015, "o", "terraform {\r\n  required_providers {\r\n    scaleway = {\r\n      source = \"scaleway/scaleway\"\r\n    }\r\n  }\r\n}\r\n\r\nprovider \"scaleway\" {\r\n  region = \"fr-par\"\r\n}"]
[4.010, "o", "\r\n$ cat output/registry-paris/variables.tf\r\n"]
[1.015, "o", "variable \"registry_name\" {\r\n  type    = string\r\n  default = \"app-images\"\r\n}\r\n\r\nvariable \"region\" {\r\n  type    = string\r\n  default = \"fr-par\"\r\n}\r\n\r\nvariable \"is_public\" {\r\n  type    = bool\r\n  default = false\r\n}"]
[5.009, "o", "\r\n# That's the loop:\r\n"]
[0.001, "o", "#   scenario YAML  ->  LLM generates HCL  ->  mock validates  ->  retry on failure\r\n"]
[0.000, "o", "# Subsecond mock feedback. No cloud credentials. No 90-second apply-cycle waits.\r\n"]
[4.012, "x", "0"]
