#!/bin/sh
# infrafactory pre-commit hook. Order matters:
#   1. gitleaks       — short-circuit before tests can print secrets to logs
#   2. go vet         — bug catcher, sub-second
#   3. gofmt -l       — reject unformatted code (staged .go only)
#   4. git diff --check — whitespace damage (trailing space, mixed indent)
#   5. large-file     — reject accidentally-staged binaries > 5MB
#   6. yaml/json      — syntax-check staged config files
#   7. visual baseline auto-refresh — if scenarios/training/*.yaml changed
#   8. make test      — full suite (Go unit + UI unit + Playwright), last
#
# Wired via `git config core.hooksPath .githooks` — run `make install-hooks`
# once per clone.

set -e

# ---------- 1. gitleaks ----------
echo "Scanning for secrets (gitleaks)..."
gitleaks protect --staged --no-banner
echo "No secrets detected."
echo ""

# ---------- 2. go vet ----------
echo "Running go vet..."
go vet ./...
echo "go vet clean."
echo ""

# ---------- 3. gofmt -l (staged .go only) ----------
# Industry-standard pattern: only check files being committed, so
# pre-existing drift in untouched files doesn't block. Every commit
# enforces clean formatting on what's being committed.
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.go$' || true)
if [ -n "$STAGED_GO" ]; then
  echo "Checking gofmt on staged .go files..."
  UNFORMATTED=$(echo "$STAGED_GO" | xargs gofmt -l 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: the following staged files are not gofmt-clean:"
    echo "$UNFORMATTED" | sed 's/^/  /'
    echo ""
    echo "Fix with: gofmt -w $(echo "$UNFORMATTED" | tr '\n' ' ')"
    exit 1
  fi
  echo "gofmt clean."
  echo ""
fi

# ---------- 4. whitespace check ----------
echo "Checking for whitespace errors..."
git diff --cached --check
echo "No whitespace errors."
echo ""

# ---------- 5. large-file guard ----------
echo "Checking for large staged files (>5MB)..."
MAX_BYTES=5242880
TOO_LARGE=""
for f in $(git diff --cached --name-only --diff-filter=ACMR); do
  [ -f "$f" ] || continue
  SIZE=$(wc -c < "$f" | tr -d ' ')
  if [ "$SIZE" -gt "$MAX_BYTES" ]; then
    MB=$((SIZE / 1024 / 1024))
    TOO_LARGE="${TOO_LARGE}  ${f} (${MB}MB)
"
  fi
done
if [ -n "$TOO_LARGE" ]; then
  echo "ERROR: the following staged files exceed 5MB:"
  printf "%s" "$TOO_LARGE"
  echo "If this is intentional, bypass with --no-verify (NOT recommended — consider git-lfs)."
  exit 1
fi
echo "No oversized files."
echo ""

# ---------- 6. yaml/json syntax ----------
STAGED_YAML=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(yaml|yml)$' || true)
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.json$' || true)
if [ -n "$STAGED_YAML" ] || [ -n "$STAGED_JSON" ]; then
  echo "Validating YAML/JSON syntax..."
  for f in $STAGED_YAML; do
    [ -f "$f" ] || continue
    if ! ERR=$(python3 -c "import yaml; yaml.safe_load(open('$f'))" 2>&1); then
      echo "ERROR: $f failed YAML parse:"
      echo "$ERR" | sed 's/^/  /'
      exit 1
    fi
  done
  for f in $STAGED_JSON; do
    [ -f "$f" ] || continue
    if ! ERR=$(python3 -c "import json; json.load(open('$f'))" 2>&1); then
      echo "ERROR: $f failed JSON parse:"
      echo "$ERR" | sed 's/^/  /'
      exit 1
    fi
  done
  echo "Config files parse clean."
  echo ""
fi

# ---------- 7. visual baseline auto-refresh (M56) ----------
# Sidebar grows by one entry per scenarios/training/*.yaml addition;
# visual masks hide content but don't constrain layout height, so the
# baselines need refresh to stay in sync. Doing it here saves a manual
# `make ui-baseline-update` + re-commit cycle. See
# project_visual_regression_masking.md for the full background.
SCENARIO_CHANGES=$(git diff --cached --name-only --diff-filter=ACDMR -- 'scenarios/training/*.yaml')
if [ -n "$SCENARIO_CHANGES" ]; then
  # Skip if baselines already staged (user ran make ui-baseline-update
  # manually); avoids redoing work.
  STAGED_BASELINES=$(git diff --cached --name-only -- 'ui/e2e/visual.spec.ts-snapshots/*.png')
  if [ -z "$STAGED_BASELINES" ]; then
    echo "Scenario file(s) changed — auto-refreshing visual baselines:"
    echo "$SCENARIO_CHANGES" | sed 's/^/  /'
    make ui-baseline-update
    git add ui/e2e/visual.spec.ts-snapshots/*.png
    echo "Regenerated baselines staged."
  else
    echo "Scenario change detected but baselines already staged — skipping auto-refresh."
  fi
  echo ""
fi

# ---------- 8. make test ----------
echo "Running make test..."
make test
echo "All tests passed."
